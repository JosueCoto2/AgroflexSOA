# ============================================================
#  AgroFlex SOA — Plantilla de variables de entorno
#  Copia como .env y rellena los valores reales.
#  NUNCA subas .env con claves reales al repositorio.
# ============================================================

# ── Base de datos MySQL ──────────────────────────────────────
DB_USER=root
DB_PASS=CAMBIAR_CONTRASENA_MYSQL_EN_PRODUCCION
MYSQL_ROOT_PASSWORD=CAMBIAR_CONTRASENA_MYSQL_EN_PRODUCCION

# ── JWT (debe ser idéntico en todos los microservicios) ──────
# Genera con: openssl rand -hex 32
JWT_SECRET=CAMBIAR_POR_SECRET_DE_AL_MENOS_256_BITS

# ── QR Service HMAC secret ───────────────────────────────────
QR_TOKEN_SECRET=CAMBIAR_POR_SECRET_QR_256_BITS

# ── Stripe (Payments Service) ────────────────────────────────
STRIPE_SECRET_KEY=sk_test_REEMPLAZAR_CON_CLAVE_REAL
STRIPE_WEBHOOK_SECRET=whsec_REEMPLAZAR_CON_CLAVE_REAL

# ── Stripe clave pública — se embebe en React en build time ──
VITE_STRIPE_PK=pk_test_REEMPLAZAR_CON_CLAVE_PUBLICA_REAL

# ── Email SMTP (Notifications Service) ───────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=tu@gmail.com
MAIL_PASS=tu_app_password
MAIL_FROM=noreply@agroflex.mx

# ── Twilio SMS (Notifications Service) ───────────────────────
TWILIO_ENABLED=true
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM=+1XXXXXXXXXX

# ── Firebase FCM (Notifications Service) ─────────────────────
FIREBASE_ENABLED=true
FIREBASE_CREDENTIALS_PATH=firebase-service-account.json

# ── Firebase Web SDK (Frontend — build time) ─────────────────
VITE_FIREBASE_API_KEY=REEMPLAZAR
VITE_FIREBASE_AUTH_DOMAIN=REEMPLAZAR.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=REEMPLAZAR
VITE_FIREBASE_STORAGE_BUCKET=REEMPLAZAR.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=REEMPLAZAR
VITE_FIREBASE_APP_ID=REEMPLAZAR

# ── Cloudinary (subida de imágenes desde frontend) ───────────
VITE_CLOUDINARY_CLOUD_NAME=REEMPLAZAR
VITE_CLOUDINARY_UPLOAD_PRESET=REEMPLAZAR

# ── Eureka (no cambiar — Docker lo override internamente) ─────
EUREKA_URL=http://localhost:8761/eureka

# ── URLs inter-servicio (no cambiar — Docker lo override) ─────
CATALOG_SERVICE_URL=http://localhost:8082
PAYMENTS_SERVICE_URL=http://localhost:8085
QR_SERVICE_URL=http://localhost:8086
ORDERS_SERVICE_URL=http://localhost:8084
NOTIFICATIONS_SERVICE_URL=http://localhost:8088
